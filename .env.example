# DigitalOcean Inference model access key (required)
# Create one at cloud.digitalocean.com → INFERENCE → Manage → Create model access key
DIGITAL_OCEAN_MODEL_ACCESS_KEY=your-key-here

# Optional: a DigitalOcean Agent as Rodney's primary brain.
# Paste the agent's endpoint URL (with or without /api/v1/chat/completions)
# and its access key. When set, the agent is tried first and the
# Inference Engine below becomes the automatic fallback.
# Kept server-side on purpose — never expose keys via VITE_* variables,
# those get compiled into the public JavaScript bundle.
AGENT_ENDPOINT=
AGENT_API_KEY=

# Optional: override Rodney's inference models (defaults shown)
# RODNEY_MODEL=anthropic-claude-4.6-sonnet
# RODNEY_FALLBACK_MODEL=anthropic-claude-haiku-4.5
